# OPENROUTER_API_KEY: Required for OpenRouter API calls.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Twitter (X) API Bearer Token for verifying user follows
TWITTER_BEARER_TOKEN="YOUR_TWITTER_BEARER_TOKEN"

# Optional: GitHub API Token for higher rate limits and private actions
GITHUB_TOKEN="YOUR_GITHUB_TOKEN"

# Telegram Bot Token for checking group/channel membership
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"